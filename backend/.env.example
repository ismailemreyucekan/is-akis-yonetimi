# ==========================================
#  PostgreSQL Veritabanı Bağlantı Ayarları
# ==========================================
#  Bu dosyayı ".env" olarak kopyalayın ve
#  kendi değerlerinizi girin:
#
#    copy .env.example .env
#
# ==========================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=is_akis_db
DB_USER=postgres
DB_PASSWORD=sifrenizi_girin

# Opsiyonel — doğrudan tam URI vermek isterseniz
# (bu dolu ise üstteki DB_* değerleri yok sayılır)
# DATABASE_URL=postgresql://postgres:sifre@localhost:5432/is_akis_db

# ==========================================
#  Uygulama Genel Ayarları
# ==========================================

SECRET_KEY=buraya-guclu-bir-anahtar-yazin
JWT_SECRET_KEY=buraya-jwt-anahtari-yazin
FLASK_ENV=development
